    "check": "expo lint && prettier . --check && tsc --noEmit",
    "rename": "tsx scripts/rename-project.ts",
    "server:dev": "pnpm --filter @repo/server dev",
    "server:build": "pnpm --filter @repo/server build"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.13",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/elements": "^2.9.15",
    "@react-navigation/native": "^7.2.2",
    "@repo/server": "workspace:*",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-query": "^5.100.6",
    "@trpc/client": "^11.17.0",
    "@trpc/tanstack-react-query": "^11.17.0",
    "expo": "~55.0.18",
    "expo-build-properties": "~55.0.13",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.28",
    "expo-device": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-image": "~55.0.9",
    "expo-linking": "~55.0.14",
    "expo-network": "~55.0.13",
    "expo-router": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "heroui-native": "^1.0.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-keyboard-controller": "~1.21.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.4",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "uniwind": "^1.6.3",
    "zod": "^4.4.1"
