  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.14",
    "connect": "^3.7.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "serve-sim": "^0.1.4",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "private": true,
  "expo": {
